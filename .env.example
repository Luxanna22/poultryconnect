# Flask environment (development | production)
FLASK_ENV=development

# Secret key — replace with a long, random string in production
SECRET_KEY=change-this-to-a-random-secret

# MySQL Connection (XAMPP default — no password)
# Format: mysql+pymysql://<user>:<password>@<host>/<database>
DATABASE_URL=mysql+pymysql://root:@localhost/poultryconnect

# If you have a MySQL root password set in XAMPP:
# DATABASE_URL=mysql+pymysql://root:yourpassword@localhost/poultryconnect
